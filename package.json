{
  "name": "jira-backup",
  "version": "1.0.0",
  "description": "Standalone CLI to backup all Jira project issues and attachments to local disk.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
